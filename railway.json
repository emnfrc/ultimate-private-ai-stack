{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE"
  },
  "deploy": {},
  "services": {
    "ollama": {
      "displayName": "Ollama LLM Server",
      "description": "Backend service running Ollama for local LLM inference",
      "icon": "https://ollama.com/public/ollama.png",
      "source": {
        "directory": "ollama"
      },
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "ollama/Dockerfile"
      },
      "deploy": {
        "startCommand": "",
        "healthcheckPath": "/api/tags",
        "healthcheckTimeout": 300,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 5
      },
      "networking": {
        "serviceDomain": {},
        "internalNetworking": true
      },
      "variables": {
        "OLLAMA_HOST": {
          "description": "Host address Ollama listens on",
          "default": "0.0.0.0"
        },
        "OLLAMA_PORT": {
          "description": "Port Ollama listens on",
          "default": "11434"
        },
        "OLLAMA_KEEP_ALIVE": {
          "description": "Duration to keep models loaded in memory (e.g., 5m, 1h, -1 for forever)",
          "default": "5m"
        },
        "OLLAMA_PRELOAD_MODEL": {
          "description": "Optional: model to auto-download at startup (e.g., llama3, mistral, phi3)",
          "default": ""
        },
        "OLLAMA_NUM_PARALLEL": {
          "description": "Number of parallel requests Ollama can handle",
          "default": "1"
        },
        "OLLAMA_MAX_LOADED_MODELS": {
          "description": "Maximum number of models loaded simultaneously",
          "default": "1"
        }
      },
      "volumes": {
        "ollama_data": {
          "mountPath": "/root/.ollama",
          "description": "Persistent storage for downloaded LLM models"
        }
      }
    },
    "open-webui": {
      "displayName": "Open WebUI",
      "description": "ChatGPT-style web interface connected to Ollama",
      "icon": "https://docs.openwebui.com/img/logo.png",
      "source": {
        "directory": "open-webui"
      },
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "open-webui/Dockerfile"
      },
      "deploy": {
        "startCommand": "",
        "healthcheckPath": "/health",
        "healthcheckTimeout": 300,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 5
      },
      "networking": {
        "serviceDomain": {
          "hasPublicDomain": true
        },
        "internalNetworking": true
      },
      "variables": {
        "OLLAMA_BASE_URL": {
          "description": "Internal Railway URL to the Ollama service",
          "default": "http://ollama.railway.internal:11434"
        },
        "PORT": {
          "description": "Port for the Open WebUI server",
          "default": "8080"
        },
        "WEBUI_AUTH": {
          "description": "Enable authentication (true/false)",
          "default": "true"
        },
        "WEBUI_SECRET_KEY": {
          "description": "Secret key for session encryption - CHANGE THIS",
          "default": "change-me-to-a-random-secret"
        },
        "ENABLE_SIGNUP": {
          "description": "Allow new user registration (true/false)",
          "default": "true"
        },
        "WEBUI_NAME": {
          "description": "Display name for the WebUI instance",
          "default": "AI Private Hub"
        },
        "DEFAULT_MODELS": {
          "description": "Comma-separated list of default models to show",
          "default": ""
        }
      },
      "volumes": {
        "webui_data": {
          "mountPath": "/app/backend/data",
          "description": "Persistent storage for user data, chat history, and configurations"
        }
      }
    }
  }
}
