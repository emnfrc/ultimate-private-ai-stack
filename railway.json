{
  "$schema": "https://railway.app/railway.schema.json",
  "name": "Ultimate Private AI Stack",
  "description": "Déployez votre propre ChatGPT privé avec Ollama et Open WebUI en un clic.",
  "icon": "https://raw.githubusercontent.com/walkxcode/dashboard-icons/main/png/ollama.png",
  "services": {
    "ollama": {
      "source": "ollama",
      "dockerfile": "Dockerfile",
      "deploy": {
        "healthcheckPath": "/api/tags",
        "healthcheckTimeout": 300,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 5
      },
      "variables": {
        "OLLAMA_HOST": "0.0.0.0",
        "OLLAMA_PORT": "11434",
        "OLLAMA_KEEP_ALIVE": "5m",
        "OLLAMA_PRELOAD_MODEL": "",
        "OLLAMA_NUM_PARALLEL": "1",
        "OLLAMA_MAX_LOADED_MODELS": "1"
      },
      "volumes": {
        "ollama_models": {
          "mountPath": "/root/.ollama"
        }
      }
    },
    "open-webui": {
      "source": "open-webui",
      "dockerfile": "Dockerfile",
      "deploy": {
        "healthcheckPath": "/health",
        "healthcheckTimeout": 300,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 5
      },
      "variables": {
        "OLLAMA_BASE_URL": "http://ollama:11434",
        "PORT": "8080",
        "WEBUI_AUTH": "true",
        "WEBUI_SECRET_KEY": "change-me-to-a-random-secret",
        "ENABLE_SIGNUP": "true",
        "WEBUI_NAME": "AI Private Hub",
        "DEFAULT_MODELS": ""
      },
      "volumes": {
        "webui_data": {
          "mountPath": "/app/backend/data"
        }
      }
    }
  }
}
